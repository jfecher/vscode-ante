{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Ante",
	"patterns": [
		{
			"include": "#keywords"
		},
		{
			"include": "#functions"
		},
		{
			"include": "#comments"
		},
		{
			"include": "#literals"
		},
		{
			"include": "#types"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#operators"
		},
		{
			"include": "#preprocs"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.ante",
					"match": "\\b(ability|and|as|block|break|can|comptime|continue|derive|do|else|exists|export|extern|fn|for|forall|freeze|given|handler|if|imm|impl|implicit|import|in|is|loop|match|module|move|mut|not|opaque|or|owned|pure|ref|resume|return|self|shared|then|type|uniq|var|via|while|with)\\b"
				}
			]
		},
		"functions": {
			"patterns": [
				{
					"comment": "definition/application head at line start: `add a b = ...`. Excludes keywords and requires a following argument (so value bindings like `x = 3` are not matched).",
					"match": "^\\s*(?!(?:ability|and|as|block|break|can|comptime|continue|derive|do|else|exists|export|extern|fn|for|forall|freeze|given|handler|if|imm|impl|implicit|import|in|is|loop|match|module|move|mut|not|opaque|or|owned|pure|ref|resume|return|self|shared|then|type|uniq|var|via|while|with)\\b)([a-z_]\\w*)(?=\\s+[a-zA-Z_0-9(\\[{\"'])",
					"captures": {
						"1": { "name": "entity.name.function.ante" }
					}
				},
				{
					"name": "entity.name.function.ante",
					"match": "[a-z_]\\w*(?= *[(\\[\"'])"
				},
				{
					"name": "entity.name.function.ante",
					"match": "[a-z_]\\w*(?= *\\{)"
				},
				{
					"name": "entity.name.function.ante",
					"match": "[a-z_]\\w*(?= *<\\|)"
				},
				{
					"name": "entity.name.function.ante",
					"match": "(?<=\\|> )[a-z_]\\w*"
				},
				{
					"name": "entity.name.function.ante",
					"match": "(?<=\\\\)\\w+"
				}
			]
		},
		"comments": {
			"patterns":[
				{
					"name": "comment.line.ante",
					"match": "//.*$"
				},
				{
					"name": "comment.block.ante",
					"begin": "/\\*",
					"end": "\\*/"
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.ante",
					"match": ":="
				},
				{
					"name": "keyword.operator.ante",
					"match": "[+\\-*/%\\^:|#&=<>!]"
				}
			]
		},
		"types": {
			"patterns": [
				{
					"name": "entity.name.type.ante",
					"match": "\\b[A-Z]\\w*\\b"
				},
				{
					"name": "entity.name.type.ante",
					"match": "'[a-z_]\\w*\\b"
				}
			]
		},
		"preprocs": {
			"patterns": [
				{
					"name": "keyword.control.ante",
					"match": "#[a-z_]\\w*"
				},
				{
					"name": "keyword.control.ante",
					"begin": "!\\[",
					"end": "]",
					"patterns": [
						{
							"include": "#comments"
						},
						{
							"include": "#literals"
						},
						{
							"include": "#types"
						},
						{
							"include": "#strings"
						},
						{
							"include": "#operators"
						}
					]
				}
			]
		},
		"literals": {
			"patterns": [
				{
					"name": "constant.numeric.ante",
					"match": "\\b[0-9_]+\\.[0-9_]+(f(32|64))?\\b"
				},
				{
					"name": "constant.numeric.ante",
					"match": "\\b[0-9_]+([ui](8|16|32|64|sz))?\\b"
				},
				{
					"name": "constant.numeric.ante",
					"match": "\\b0b[01_]+([ui](8|16|32|64|sz))?\\b"
				},
				{
					"name": "constant.numeric.ante",
					"match": "\\b0o[0-7_]+([ui](8|16|32|64|sz))?\\b"
				},
				{
					"name": "constant.numeric.ante",
					"match": "\\b0x[0-9A-Fa-f_]+([ui](8|16|32|64|sz))?\\b"
				},
				{
					"name": "constant.other.ante",
					"match": "\\b(true|false)\\b"
				},
				{
					"name": "constant.character.ante",
					"match": "'.'"
				},
				{
					"name": "constant.character.escape.ante",
					"match": "'\\\\([abfnrtv]|([0-9]+))'"
				}
			]
		},
		"strings": {
			"name": "string.quoted.double.ante",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.ante",
					"match": "\\\\([abfnrtv]|([0-9]+))"
				},
				{
					"name": "meta.interpolation.ante",
					"begin": "\\${",
					"end": "}",
					"beginCaptures": {
						"0": { "name": "punctuation.section.interpolation.ante" }
					},
					"endCaptures": {
						"0": { "name": "punctuation.section.interpolation.ante" }
					},
					"patterns": [
						{ "include": "#keywords" },
						{ "include": "#comments" },
						{ "include": "#literals" },
						{ "include": "#types" },
						{ "include": "#operators" },
						{ "include": "#strings" }
					]
				},
				{
					"name": "variable.other.interpolation.ante",
					"match": "\\$\\w+"
				}
			]
		}
	},
	"scopeName": "source.ante"
}
